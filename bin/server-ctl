#!/usr/bin/env bash
# Backward-compat alias for `dreamux dispatcher ...` / `dreamux server status`.
# Pre-monorepo (issue #4) the admin CLI lived at <repo>/bin/server-ctl; keep
# that path alive for operators with old PATH entries. New tooling should
# call `dreamux ...` directly.
set -eu

SOURCE="${BASH_SOURCE[0]}"
hop=0
while [ -L "$SOURCE" ]; do
  hop=$((hop + 1))
  if [ "$hop" -gt 40 ]; then
    echo "server-ctl: too many symlink hops resolving $SOURCE" >&2
    exit 1
  fi
  TARGET="$(readlink "$SOURCE")"
  if [ "${TARGET:0:1}" = "/" ]; then
    SOURCE="$TARGET"
  else
    SOURCE="$(dirname -- "$SOURCE")/$TARGET"
  fi
done

ROOT="$(cd -- "$(dirname -- "$SOURCE")/.." &> /dev/null && pwd)"
exec "$ROOT/packages/dreamux/bin/server-ctl" "$@"
