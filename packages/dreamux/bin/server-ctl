#!/usr/bin/env bash
# Launcher for server-ctl. See bin/server for resolution details.
set -eu

SOURCE="${BASH_SOURCE[0]}"
hop=0
while [ -L "$SOURCE" ]; do
  hop=$((hop + 1))
  if [ "$hop" -gt 40 ]; then
    echo "server-ctl: too many symlink hops resolving $SOURCE" >&2
    exit 1
  fi
  TARGET="$(readlink "$SOURCE")"
  if [ "${TARGET:0:1}" = "/" ]; then
    SOURCE="$TARGET"
  else
    SOURCE="$(dirname -- "$SOURCE")/$TARGET"
  fi
done

DIR="$(cd -- "$(dirname -- "$SOURCE")/.." &> /dev/null && pwd)"
TARGET="$DIR/dist/cli/server-ctl.js"
if [ ! -f "$TARGET" ]; then
  echo "server-ctl: $TARGET is missing." >&2
  echo "Build it first from the repo root: node common/scripts/install-run-rush.js build (rush build)." >&2
  exit 1
fi
exec node "$TARGET" "$@"
