{
  "name": "@excitedjs/dreamux",
  "version": "0.1.0",
  "description": "Codex-host server — single-session MVP. One node process hosts N dispatchers, each binding 1 Feishu bot + 1 Codex thread.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/excitedjs/dreamux.git",
    "directory": "packages/dreamux"
  },
  "homepage": "https://github.com/excitedjs/dreamux/tree/main/packages/dreamux#readme",
  "bugs": "https://github.com/excitedjs/dreamux/issues",
  "type": "module",
  "main": "./dist/server.js",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.7"
  },
  "bin": {
    "dreamux": "./bin/dreamux",
    "dreamux-server": "./bin/server",
    "server-ctl": "./bin/server-ctl"
  },
  "files": [
    "bin",
    "dist",
    "db",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.64.0",
    "better-sqlite3": "^11.5.0",
    "marked": "^15.0.12",
    "smol-toml": "^1.6.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@types/ws": "^8.5.13",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
